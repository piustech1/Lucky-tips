{
  "entities": {
    "Prediction": {
      "title": "Prediction",
      "description": "A match prediction entity with logos and market metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "time": { "type": "string" },
        "league": { "type": "string" },
        "leagueLogo": { "type": "string" },
        "homeTeam": { "type": "string" },
        "homeLogo": { "type": "string" },
        "awayTeam": { "type": "string" },
        "awayLogo": { "type": "string" },
        "tip": { "type": "string" },
        "odds": { "type": "string" },
        "category": { "type": "string", "enum": ["free", "vip", "1x", "x2", "bts", "over25", "under25"] },
        "status": { "type": "string", "enum": ["won", "lost", "pending"] },
        "isVip": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "time", "league", "homeTeam", "awayTeam", "tip", "odds", "category", "status", "isVip", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "User profile and subscription state",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string" },
        "subscriptionTier": { "type": "string", "enum": ["free", "vip"] },
        "subscriptionExpiry": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "subscriptionTier", "isAdmin", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System broadcast notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["info", "success", "alert"] },
        "target": { "type": "string", "enum": ["all", "vip"] }
      },
      "required": ["title", "message", "timestamp", "type", "target"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Subscription payment record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "plan": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "active", "expired"] },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "currency", "plan", "status", "date"]
    }
  },
  "firestore": {
    "/predictions/{predictionId}": {
      "schema": "Prediction",
      "description": "Global collection of curated tips"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Public and targeted alerts"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial records"
    },
    "/admins/{userId}": {
      "schema": { "type": "object", "properties": { "role": { "type": "string" } } },
      "description": "Trusted admin registry"
    }
  }
}
